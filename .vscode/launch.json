{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Debug Simulation",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/server",
            "cwd": "${workspaceFolder}",
            "args": [],
            "env": { "CONFIG_PATH": "${workspaceFolder}/config.yaml" }
        },
        {
            "name": "Run Server (Deterministic seed)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/server",
            "cwd": "${workspaceFolder}",
            "args": [
                "--deterministic",
                "--seed",
                "7"
            ],
            "env": { "CONFIG_PATH": "${workspaceFolder}/config.yaml" }
        },
        {
            "name": "Run Server (Mock Topology 50 Nodes)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/server",
            "cwd": "${workspaceFolder}",
            "args": [
                "--mock-topology"
            ],
            //"env": { "CONFIG_PATH": "${workspaceFolder}/config.yaml" }
        },
        {
            "name": "Run Seed Batch (1:150, 1000 ticks)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/batch",
            "cwd": "${workspaceFolder}",
            "args": [
                "--batch-seeds",
                "1:150",
                "--batch-ticks",
                "1000",
                "--batch-out",
                "${workspaceFolder}/out/seeds_1_150.csv"
            ],
            //"env": { "CONFIG_PATH": "${workspaceFolder}/config.yaml" }
        }
    ]
}
