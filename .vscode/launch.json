{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Server (Random)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}"
        },
        {
            "name": "Run Server (Deterministic seed)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}",
            "args": [
                "--deterministic",
                "--seed",
                "7"
            ]
        },
        {
            "name": "Run Seed Batch (1:150, 1000 ticks)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}",
            "args": [
                "--batch-seeds",
                "1:150",
                "--batch-ticks",
                "1000",
                "--batch-out",
                "${workspaceFolder}/out/seeds_1_150.csv"
            ]
        }
    ]
}
